{
  "name": "hider",
  "version": "1.0.0",
  "description": "Stealth novel reader - read discreetly with transparent overlay",
  "main": "main.js",
  "scripts": {
    "start": "unset ELECTRON_RUN_AS_NODE && electron .",
    "build": "unset ELECTRON_RUN_AS_NODE && electron-builder",
    "build:mac": "unset ELECTRON_RUN_AS_NODE && electron-builder --mac",
    "build:win": "unset ELECTRON_RUN_AS_NODE && electron-builder --win"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "type": "commonjs",
  "devDependencies": {
    "electron": "^33.4.11",
    "electron-builder": "^26.8.1"
  },
  "dependencies": {
    "adm-zip": "^0.5.16"
  },
  "build": {
    "appId": "com.hider.reader",
    "productName": "Hider",
    "electronLanguages": ["zh-CN", "en-US"],
    "mac": {
      "category": "public.app-category.books",
      "identity": null,
      "hardenedRuntime": true,
      "gatekeeperAssess": false,
      "entitlements": "build/entitlements.mac.plist",
      "entitlementsInherit": "build/entitlements.mac.plist",
      "target": [
        "dmg"
      ]
    },
    "win": {
      "target": [
        "portable"
      ],
      "artifactName": "${productName}-${version}-win-${arch}.${ext}"
    },
    "files": [
      "main.js",
      "preload.js",
      "renderer/**/*",
      "node_modules/adm-zip/**/*"
    ],
    "asar": true
  }
}
